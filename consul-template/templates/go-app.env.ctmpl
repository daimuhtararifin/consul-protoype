{{ $env := env "APP_ENV" }}
TZ={{ keyOrDefault (printf "config/%s/shared/TZ" $env) "Asia/Jakarta" }}
LOG_FORMAT={{ keyOrDefault (printf "config/%s/shared/LOG_FORMAT" $env) "text" }}
CONFIG_VERSION={{ keyOrDefault (printf "config/%s/shared/CONFIG_VERSION" $env) "local" }}
APP_NAME={{ keyOrDefault (printf "config/%s/go-app/APP_NAME" $env) "unknown" }}
APP_PORT={{ keyOrDefault (printf "config/%s/go-app/APP_PORT" $env) "8000" }}
LOG_LEVEL={{ keyOrDefault (printf "config/%s/go-app/LOG_LEVEL" $env) "info" }}